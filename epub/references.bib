@misc{Zupon2021,
    author = "Zupon, Andrew and Crew, Evan and Ritchie, Sandy",
    title = "Text {Normalization} for {Low}-{Resource} {Languages} of {Africa}",
    copyright = "Creative Commons Attribution 4.0 International",
    url = "https://arxiv.org/abs/2103.15845",
    doi = "10.48550/ARXIV.2103.15845",
    abstract = "Training data for machine learning models can come from many different sources, which can be of dubious quality. For resource-rich languages like English, there is a lot of data available, so we can afford to throw out the dubious data. For low-resource languages where there is much less data available, we can't necessarily afford to throw out the dubious data, in case we end up with a training set which is too small to train a model. In this study, we examine the effects of text normalization and data set quality for a set of low-resource languages of Africa -- Afrikaans, Amharic, Hausa, Igbo, Malagasy, Somali, Swahili, and Zulu. We describe our text normalizer which we built in the Pynini framework, a Python library for finite state transducers, and our experiments in training language models for African languages using the Natural Language Toolkit (NLTK), an open-source Python library for NLP.",
    urldate = "2025-02-14",
    publisher = "arXiv",
    year = "2021",
    note = "Version Number: 1",
    keywords = "FOS: Computer and information sciences, Computation and Language (cs.CL)",
    file = "Zupon et al. \_2021\_Text Normalization for Low-Resource Languages of Africa.pdf:/home/raynier/Insync/raynierx@gmail.com/Google Drive/\_\_\_\_LIBRARY/ZOT\_LIBR/Zupon et al. \_2021\_Text Normalization for Low-Resource Languages of Africa.pdf:application/pdf"
}

