@article{Dai2025,
    author = "Dai, Huteng",
    title = "An exception-filtering approach to phonotactic learning",
    volume = "42",
    issn = "0952-6757, 1469-8188",
    url = "https://www.cambridge.org/core/journals/phonology/article/an-exceptionfiltering-approach-to-phonotactic-learning/58AECB02B7F59B91D4D4C974383F41B2",
    doi = "10.1017/S0952675725000028",
    abstract = "Phonotactic learning has been a fertile ground for research in the field of phonology. However, the challenge of lexical exceptions in phonotactic learning remains largely unexplored. Traditional learning models, which typically assume all observed input data to be grammatical, often blur the distinction between lexical exceptions and grammatical words, consequently skewing the learning results. To address this issue, this article innovates a categorical-grammar-plus-exception-filtering approach that harnesses the discrete nature of categorical grammars to filter out lexical exceptions using statistical criteria adapted from probabilistic models. Applied to naturalistic corpora from English, Polish and Turkish, the learnt grammars showed a high correlation with the acceptability judgements in behavioural experiments. Compared to benchmark models, the model performs increasingly better with data that contain a higher proportion of lexical exceptions, reaching its peak in learning Turkish non-local vowel phonotactics, highlighting its ability to handle lexical exceptions.",
    language = "en",
    urldate = "2025-05-04",
    journal = "Phonology",
    month = "January",
    year = "2025",
    keywords = "acceptability, categorical grammar, exceptionality, frequency, indirect negative evidence, onsets, phonological learning, phonotactics, vowel harmony",
    pages = "e5",
    file = "Dai \_2025\_An exception-filtering approach to phonotactic learning.pdf:/home/raynier/Insync/raynierx@gmail.com/Google Drive/\_\_\_\_LIBRARY/ZOT\_LIBR/Dai \_2025\_An exception-filtering approach to phonotactic learning.pdf:application/pdf"
}

